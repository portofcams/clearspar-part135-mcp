# Clearspar Part 135 MCP — environment

# Base URL of the live Clearspar app that serves GET /api/prospects.
CLEARSPAR_BASE_URL=https://clearspar.binnacleai.com

# REQUIRED. The /api/prospects endpoint is key-gated (401 without it).
# This is the value of the DIGEST_API_KEY env var on the `takeoff-app`
# Docker container (host 144.202.116.229). Retrieve it with:
#   docker exec takeoff-app printenv DIGEST_API_KEY
# Sent as the `X-API-Key` header. Placeholder below — do NOT commit a real key.
CLEARSPAR_API_KEY=replace-with-DIGEST_API_KEY-value
